DATABASE_URL="file:./dev.db"
JWT_SECRET="***"
PAYMENT_PROVIDER="alipay"

# 支付宝配置 - 个人开发者使用「当面付」
# 1. APPID：在支付宝开放平台应用详情页查看
ALIPAY_APP_ID="2021001234567890"

# 2. 应用私钥：从开发助手生成，格式类似：MIIEvgIBADA...（很长一串）
# ⚠️ 注意：不要包含 -----BEGIN RSA PRIVATE KEY----- 这些头尾
ALIPAY_PRIVATE_KEY="***"

# 3. 支付宝公钥：在平台配置应用公钥后获得
ALIPAY_PUBLIC_KEY="***"

# 4. 网关地址：沙箱用 dev，正式环境用 gateway.do
# 沙箱测试：https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 正式环境：https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"

# 5. 你的应用公网地址（用于支付宝回调）
# 本地开发需要用内网穿透工具，比如 ngrok、frp
# 例如：https://abc123.ngrok.io
NEXT_PUBLIC_APP_URL="http://localhost:3000"
