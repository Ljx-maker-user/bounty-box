# Database
DATABASE_URL="file:./dev.db"

# JWT Secret
JWT_SECRET="bounty…2024"

# Payment Provider: mock | alipay | wechat
PAYMENT_PROVIDER="mock"

# 支付宝配置 - 个人开发者使用「当面付」
# 1. APPID：在支付宝开放平台应用详情页查看
ALIPAY_APP_ID=""
# 2. 应用私钥：从开发助手生成（去掉首尾的 -----BEGIN/END 标记）
ALIPAY_PRIVATE_KEY=""
# 3. 支付宝公钥：在平台配置后获得
ALIPAY_PUBLIC_KEY=""
# 4. 网关地址：沙箱用 sandbox，正式用 gateway.do
ALIPAY_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"

# WeChat Pay Config (when PAYMENT_PROVIDER=wechat)
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
